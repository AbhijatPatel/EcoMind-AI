# Copy this file to .env in the repo root to customize `docker compose up`.
# docker-compose.yml reads these via ${VAR:-default} interpolation, so this
# file is optional — sensible (non-secret) defaults are already baked into
# docker-compose.yml itself. You mainly need this file to set a real
# ANTHROPIC_API_KEY and a real JWT_SECRET.

# --- Required for AI chat to actually work ---
ANTHROPIC_API_KEY=

# --- Security (change before any non-local use) ---
JWT_SECRET=replace-with-a-long-random-value

# --- Database (defaults are fine for local Docker use) ---
POSTGRES_USER=ecomind
POSTGRES_PASSWORD=ecomind
POSTGRES_DB=ecomind

# --- Ports (change if 3000/8000 are already taken on your machine) ---
FRONTEND_PORT=3000
BACKEND_PORT=8000

# --- Must match whatever port/host the browser will actually use to reach
# the backend directly. If you change BACKEND_PORT above, update this too. ---
VITE_API_BASE_URL=http://localhost:8000

# --- CORS: must include the origin the browser loads the frontend from ---
CORS_ALLOWED_ORIGINS=["http://localhost:3000"]

ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO
