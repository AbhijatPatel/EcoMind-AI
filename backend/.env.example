# Copy this file to .env and fill in real values. Never commit .env itself.

APP_NAME=EcoMind AI
ENVIRONMENT=development
DEBUG=true

# Async SQLAlchemy connection string (asyncpg driver)
DATABASE_URL=postgresql+asyncpg://ecomind:ecomind@localhost:5432/ecomind
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=5

# Auth
JWT_SECRET=replace-with-a-long-random-value
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# AI provider (set only the one you use)
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# CORS — comma-separated list is parsed into a JSON array by pydantic-settings
CORS_ALLOWED_ORIGINS=["http://localhost:5173"]

LOG_LEVEL=INFO
